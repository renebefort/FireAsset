@page "/ueber"
@attribute [Authorize]
@inject AppInfoService AppInfo

<PageTitle>Über FireAsset · Asset Manager</PageTitle>

<RadzenText TextStyle="TextStyle.H4" class="rz-mb-3">Über FireAsset</RadzenText>

<RadzenCard Style="max-width: 640px">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem" class="rz-mb-3">
        <RadzenIcon Icon="local_fire_department" Style="font-size:2rem; color:var(--rz-primary);" />
        <div>
            <RadzenText TextStyle="TextStyle.H6" class="rz-my-0">FireAsset – Asset Manager</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" class="rz-my-0" Style="color:#6b7280;">
                Verwaltung von Geräten, Standorten und Prüfungen
            </RadzenText>
        </div>
    </RadzenStack>

    <table style="border-collapse:collapse;">
        <tbody>
            <tr>
                <td style="padding:0.35rem 1.5rem 0.35rem 0; font-weight:600;">Version</td>
                <td style="padding:0.35rem 0;">@_version</td>
            </tr>
            <tr>
                <td style="padding:0.35rem 1.5rem 0.35rem 0; font-weight:600;">Build-Datum</td>
                <td style="padding:0.35rem 0;">@(_buildDate?.ToString("dd.MM.yyyy HH:mm") ?? "unbekannt")</td>
            </tr>
            <tr>
                <td style="padding:0.35rem 1.5rem 0.35rem 0; font-weight:600;">Repository</td>
                <td style="padding:0.35rem 0;">
                    <a href="@AppInfoService.RepositoryUrl" target="_blank" rel="noopener">@AppInfoService.RepositoryUrl</a>
                </td>
            </tr>
        </tbody>
    </table>
</RadzenCard>

@code {
    private string _version = "…";
    private DateTime? _buildDate;

    protected override async Task OnInitializedAsync()
    {
        _buildDate = AppInfo.GetBuildDate();
        _version = await AppInfo.GetVersionAsync();
    }
}
