@page "/changelog"
@attribute [Authorize]
@inject ChangelogService ChangelogService

<PageTitle>Changelog · Asset Manager</PageTitle>

<RadzenText TextStyle="TextStyle.H4" class="rz-mb-3">Changelog</RadzenText>

@if (_groups is null)
{
    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else if (_groups.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">
        Kein Änderungsprotokoll verfügbar (die Anwendung läuft außerhalb eines Git-Repositories).
    </RadzenAlert>
}
else
{
    @foreach (var group in _groups)
    {
        <RadzenCard class="rz-mb-3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" class="rz-mb-2">
                <RadzenText TextStyle="TextStyle.H6" class="rz-my-0">@group.Title</RadzenText>
                @if (group.Date is DateTime date)
                {
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-my-0">@date.ToString("dd.MM.yyyy")</RadzenText>
                }
            </RadzenStack>
            <ul style="margin: 0; padding-left: 1.25rem;">
                @foreach (var entry in group.Entries)
                {
                    <li style="margin-bottom: 0.25rem;">
                        @entry.Subject
                        <span style="color: #9ca3af; font-size: 0.8rem;"> · @entry.Date.ToString("dd.MM.yyyy") · @entry.Hash</span>
                    </li>
                }
            </ul>
        </RadzenCard>
    }
}

@code {
    private List<ChangelogService.Group>? _groups;

    protected override async Task OnInitializedAsync()
    {
        _groups = await ChangelogService.GetChangelogAsync();
    }
}
