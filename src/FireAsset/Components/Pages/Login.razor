@page "/login"
@layout EmptyLayout
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject UserService UserService
@inject LoginThrottleService LoginThrottle
@inject NavigationManager Navigation

<PageTitle>Anmelden · Asset Manager</PageTitle>

<div class="login-page">
    <div class="login-card">
        <h1 class="login-title">Asset Manager</h1>
        <p class="login-subtitle">Bitte melden Sie sich an.</p>

        <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="login-error">@_errorMessage</div>
            }

            <label class="login-label" for="email">E-Mail</label>
            <InputText id="email" class="login-input" @bind-Value="Input.Email" autocomplete="username" />
            <ValidationMessage For="() => Input.Email" />

            <label class="login-label" for="password">Passwort</label>
            <InputText id="password" type="password" class="login-input" @bind-Value="Input.Password" autocomplete="current-password" />
            <ValidationMessage For="() => Input.Password" />

            <button type="submit" class="login-button">Anmelden</button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Kein Property-Initializer (BL0008): wird in OnInitialized gesetzt, falls kein Formpost vorliegt.
    [SupplyParameterFromForm]
    private LoginModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? _errorMessage;

    protected override void OnInitialized() => Input ??= new LoginModel();

    private async Task LoginUser()
    {
        if (LoginThrottle.GetLockoutRemaining(Input.Email) is TimeSpan remaining)
        {
            _errorMessage = "Zu viele fehlgeschlagene Anmeldeversuche. " +
                            $"Bitte in {Math.Ceiling(remaining.TotalMinutes)} Minute(n) erneut versuchen.";
            return;
        }

        var user = await UserService.ValidateCredentialsAsync(Input.Email, Input.Password);
        if (user is null)
        {
            LoginThrottle.RegisterFailure(Input.Email);
            _errorMessage = "E-Mail oder Passwort ist ungültig.";
            return;
        }
        LoginThrottle.RegisterSuccess(Input.Email);

        var claims = new List<Claim>
        {
            new(ClaimTypes.NameIdentifier, user.Id.ToString()),
            new(ClaimTypes.Name, user.FullName),
            new(ClaimTypes.Email, user.Email),
        };
        if (user.IsAdmin)
        {
            claims.Add(new Claim(ClaimTypes.Role, "Administrator"));
        }

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, principal);

        Navigation.NavigateTo(GetSafeReturnUrl(ReturnUrl));
    }

    /// <summary>
    /// Lässt nur lokale relative Ziele zu (kein Open Redirect über "//host", "/\host" oder
    /// absolute URLs mit Schema).
    /// </summary>
    private static string GetSafeReturnUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl)) return "/";
        var trimmed = returnUrl.TrimStart('/', '\\', ' ');
        if (trimmed.Length == 0 || trimmed.Contains('\\') || trimmed.Contains("//") || trimmed.Contains(':'))
        {
            return "/";
        }
        return "/" + trimmed;
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "Bitte E-Mail eingeben.")]
        [EmailAddress(ErrorMessage = "Ungültige E-Mail-Adresse.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Bitte Passwort eingeben.")]
        public string Password { get; set; } = string.Empty;
    }
}
