@inject ArticleService ArticleService
@inject LocationService LocationService
@inject NotificationService Notifications
@inject DialogService Dialogs

<RadzenStack Gap="0.85rem">
    <RadzenRow Gap="0.75rem" AlignItems="AlignItems.End">
        <RadzenColumn Size="12" SizeMd="8">
            <label class="fa-label">Identifikation / Name</label>
            <input class="fa-input" @bind="_article.Identification" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMd="2">
            <label class="fa-checkbox"><input type="checkbox" @bind="_article.IsActive" /> Aktiv</label>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMd="2">
            <label class="fa-checkbox" title="Gerät aus dem Pool eines externen Dienstleisters (FTZ): einmaliger Prüfzyklus ohne Folgeaufgaben.">
                <input type="checkbox" @bind="_article.IsPoolDevice" /> FTZ-Pool-Gerät
            </label>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="12" SizeMd="6">
            <label class="fa-label">Kategorie</label>
            <RadzenDropDown @bind-Value="_article.CategoryId"
                            Data="@_categories" TextProperty="Name" ValueProperty="Id"
                            AllowFiltering="true"
                            FilterAsYouType="true"
                            FilterOperator="StringFilterOperator.Contains"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Placeholder="Tippen zum Filtern…"
                            Style="width: 100%" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="6">
            <label class="fa-label">Standort</label>
            <RadzenDropDown @bind-Value="_article.LocationId"
                            Data="@_locationOptions" TextProperty="Path" ValueProperty="Id"
                            AllowFiltering="true"
                            FilterAsYouType="true"
                            AllowClear="true"
                            FilterOperator="StringFilterOperator.Contains"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Placeholder="(kein Standort)"
                            Style="width: 100%" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="6" SizeMd="4"><label class="fa-label">Hersteller</label><input class="fa-input" @bind="_article.Manufacturer" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="4"><label class="fa-label">Typ / Modell</label><input class="fa-input" @bind="_article.Type" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="4"><label class="fa-label">Seriennummer</label><input class="fa-input" @bind="_article.SerialNumber" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="4"><label class="fa-label">Herstellernummer</label><input class="fa-input" @bind="_article.ManufacturerNumber" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="4"><label class="fa-label">Inventarnummer</label><input class="fa-input" @bind="_article.InventoryNumber" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="4"><label class="fa-label">Barcode</label><input class="fa-input" @bind="_article.Barcode" /></RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="6" SizeMd="3"><label class="fa-label">Anschaffungsdatum</label><input type="date" class="fa-input" @bind="_article.AcquisitionDate" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="3"><label class="fa-label">Produktionsdatum</label><input type="date" class="fa-input" @bind="_productionDate" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="3"><label class="fa-label">Ausmusterung</label><input type="date" class="fa-input" @bind="_decommissionDate" /></RadzenColumn>
        <RadzenColumn Size="6" SizeMd="3"><label class="fa-label">Ende-Datum</label><input type="date" class="fa-input" @bind="_endDate" /></RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="6" SizeMd="3">
            <label class="fa-label">Einkaufspreis (€)</label>
            <input type="number" step="0.01" min="0" class="fa-input" @bind="_article.PurchasePrice" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMd="5">
            <label class="fa-label">Rechtsgrundlage</label>
            <input class="fa-input" @bind="_article.LegalBasis" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="12" SizeMd="8">
            <label class="fa-label">Beschreibung</label>
            <textarea class="fa-input fa-textarea" rows="5" @bind="_article.Description"></textarea>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="4">
            <label class="fa-label">Foto</label>
            <div style="display:flex; gap:0.75rem; align-items:flex-start;">
                @if (_photoPreviewDataUrl is not null)
                {
                    <img src="@_photoPreviewDataUrl" alt="Artikel-Foto"
                         style="width:96px; height:96px; object-fit:cover; border:1px solid #e5e7eb; border-radius:6px; flex:0 0 auto;" />
                }
                else
                {
                    <div style="width:96px; height:96px; flex:0 0 auto; display:flex; align-items:center; justify-content:center; background:#f3f4f6; border:1px solid #e5e7eb; border-radius:6px; color:#9ca3af;">
                        <RadzenIcon Icon="image" Style="font-size:2rem;" />
                    </div>
                }
                <div style="display:flex; flex-direction:column; gap:0.4rem; min-width:0;">
                    <InputFile OnChange="OnPhotoSelected" accept="image/*" />
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-my-0">Wird auf max. 1024 px verkleinert.</RadzenText>
                    @if (_photoPreviewDataUrl is not null)
                    {
                        <RadzenButton Text="Foto entfernen" Icon="delete" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="RemovePhoto" />
                    }
                    @if (!string.IsNullOrEmpty(_photoError))
                    {
                        <span style="color:#dc2626; font-size:0.85rem;">@_photoError</span>
                    }
                </div>
            </div>
        </RadzenColumn>
    </RadzenRow>

    <RadzenText TextStyle="TextStyle.Caption">
        Beim Anlegen werden automatisch Aufgaben für alle aktiven Intervalle der gewählten Kategorie erzeugt
        (erste Fälligkeit = Anschaffungsdatum + Rhythmus).
        <br />
        <strong>FTZ-Pool-Gerät:</strong> Der Prüfzyklus läuft nur einmal – beim Abschluss einer Aufgabe wird
        keine Folgeaufgabe erzeugt. Sind alle Aufgaben erledigt, wird der Artikel automatisch stillgelegt
        (inaktiv, Ende-Datum = Datum der letzten Aufgabe).
    </RadzenText>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(false)" />
        <RadzenButton Text="Speichern" ButtonStyle="ButtonStyle.Primary" Icon="save" Click="Save" Disabled="@_saving" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public int? ArticleId { get; set; }

    /// <summary>Id eines Artikels, dessen Daten als Vorlage für einen neuen Artikel dienen.</summary>
    [Parameter] public int? CopyFromArticleId { get; set; }

    [Parameter] public int? UserId { get; set; }

    private record LocationOption(int Id, string Path);

    private bool _saving;
    private Article _article = new() { AcquisitionDate = DateTime.Today, IsActive = true };
    private List<Category> _categories = new();
    private List<LocationOption> _locationOptions = new();

    // Nullable Datumsfelder über Zwischenspeicher (native date-Input).
    private DateTime? _productionDate;
    private DateTime? _decommissionDate;
    private DateTime? _endDate;

    // Foto: bereits verkleinertes Bild wird bis zum Speichern zwischengehalten.
    private const long MaxPhotoUploadBytes = 20L * 1024 * 1024;
    private ImageProcessing.ProcessedImage? _photoProcessed;
    private string? _photoPreviewDataUrl;
    private string? _photoError;
    private bool _removePhoto;

    protected override async Task OnInitializedAsync()
    {
        _categories = await ArticleService.GetActiveCategoriesAsync();

        var locations = await LocationService.GetAllAsync();
        var byId = locations.ToDictionary(l => l.Id);
        _locationOptions = locations
            .Select(l => new LocationOption(l.Id, LocationService.BuildPath(l, byId)))
            .OrderBy(o => o.Path)
            .ToList();

        if (ArticleId is int id)
        {
            var existing = await ArticleService.GetByIdAsync(id);
            if (existing is not null) _article = existing;
        }
        else if (CopyFromArticleId is int copyId)
        {
            var source = await ArticleService.GetByIdAsync(copyId);
            if (source is not null) _article = CreateCopy(source);
        }

        _productionDate = _article.ProductionDate;
        _decommissionDate = _article.DecommissionDate;
        _endDate = _article.EndDate;

        // Vorhandenes Foto (nur beim Bearbeiten) als Vorschau laden.
        if (_article.Id != 0)
        {
            var thumb = await ArticleService.GetPhotoAsync(_article.Id, thumbnail: true);
            if (thumb is not null)
            {
                _photoPreviewDataUrl = $"data:{thumb.ContentType};base64,{Convert.ToBase64String(thumb.Data)}";
            }
        }
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        _photoError = null;
        var file = e.File;
        if (file.Size > MaxPhotoUploadBytes)
        {
            _photoError = "Das Bild ist zu groß (max. 20 MB).";
            return;
        }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxPhotoUploadBytes).CopyToAsync(ms);
            var processed = ImageProcessing.TryProcess(ms.ToArray());
            if (processed is null)
            {
                _photoError = "Die Datei ist kein gültiges Bild.";
                return;
            }
            _photoProcessed = processed;
            _removePhoto = false;
            _photoPreviewDataUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(processed.Thumbnail)}";
        }
        catch (Exception)
        {
            _photoError = "Das Bild konnte nicht gelesen werden.";
        }
    }

    private void RemovePhoto()
    {
        _photoProcessed = null;
        _photoPreviewDataUrl = null;
        _photoError = null;
        _removePhoto = true;
    }

    private async Task Save()
    {
        if (_saving) return;
        if (string.IsNullOrWhiteSpace(_article.Identification))
        {
            Notify("Die Identifikation / der Name ist erforderlich.");
            return;
        }
        if (_article.CategoryId == 0)
        {
            Notify("Bitte eine Kategorie wählen.");
            return;
        }
        if (!string.IsNullOrWhiteSpace(_article.Barcode) &&
            await ArticleService.BarcodeExistsAsync(_article.Barcode, _article.Id == 0 ? null : _article.Id))
        {
            Notify("Dieser Barcode wird bereits verwendet.");
            return;
        }

        _article.ProductionDate = _productionDate;
        _article.DecommissionDate = _decommissionDate;
        _article.EndDate = _endDate;

        _saving = true;
        try
        {
            var (error, messages) = _article.Id == 0
                ? await ArticleService.CreateAsync(_article, UserId)
                : await ArticleService.UpdateAsync(_article, UserId);
            if (error is not null)
            {
                Notify(error);
                return;
            }
            // Foto nach erfolgreicher Speicherung übernehmen (Artikel-Id ist jetzt gesetzt).
            if (_photoProcessed is not null)
            {
                await ArticleService.SavePhotoAsync(_article.Id, _photoProcessed);
            }
            else if (_removePhoto)
            {
                await ArticleService.DeletePhotoAsync(_article.Id);
            }

            foreach (var msg in messages)
            {
                Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "Aufgabenanlage", Detail = msg, Duration = 8000 });
            }
            Dialogs.Close(true);
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>
    /// Kopie als neuer Artikel: gerätespezifische Kennungen (Barcode, Serien- und
    /// Inventarnummer) bleiben leer, alle übrigen Stammdaten werden übernommen.
    /// </summary>
    private static Article CreateCopy(Article source) => new()
    {
        Identification = $"{source.Identification} (Kopie)",
        Manufacturer = source.Manufacturer,
        Type = source.Type,
        ManufacturerNumber = source.ManufacturerNumber,
        PurchasePrice = source.PurchasePrice,
        AcquisitionDate = source.AcquisitionDate,
        ProductionDate = source.ProductionDate,
        DecommissionDate = source.DecommissionDate,
        LegalBasis = source.LegalBasis,
        EndDate = source.EndDate,
        Description = source.Description,
        CategoryId = source.CategoryId,
        LocationId = source.LocationId,
        IsActive = source.IsActive,
        IsPoolDevice = source.IsPoolDevice,
    };

    private void Notify(string message) =>
        Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Hinweis", Detail = message, Duration = 4000 });
}
