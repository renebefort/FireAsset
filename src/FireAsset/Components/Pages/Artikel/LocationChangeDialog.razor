@inject ArticleService ArticleService
@inject DialogService Dialogs

<RadzenStack Gap="0.85rem">
    <RadzenText TextStyle="TextStyle.Body2">
        Scannen (oder tippen) Sie den Barcode des Artikels und anschließend den Barcode des Zielstandorts.
    </RadzenText>

    <div>
        <label class="fa-label">Artikel-Barcode</label>
        <input class="fa-input" @bind="_articleBarcode" @bind:event="oninput" @ref="_articleBox" @onkeydown="OnArticleKeyDown" />
    </div>
    <div>
        <label class="fa-label">Zielstandort-Barcode</label>
        <input class="fa-input" @bind="_locationBarcode" @bind:event="oninput" @ref="_locationBox" @onkeydown="OnLocationKeyDown" />
    </div>

    @if (_result is not null)
    {
        <RadzenAlert AlertStyle="@(_ok ? AlertStyle.Success : AlertStyle.Danger)" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">
            @_result
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Schließen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(_anyChange)" />
        <RadzenButton Text="Umlagern" ButtonStyle="ButtonStyle.Primary" Icon="swap_horiz" Click="Move" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public int? UserId { get; set; }

    private string _articleBarcode = string.Empty;
    private string _locationBarcode = string.Empty;
    private string? _result;
    private bool _ok;
    private bool _anyChange;
    private bool _moving;
    private ElementReference _articleBox;
    private ElementReference _locationBox;

    private async Task OnArticleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter")
        {
            await _locationBox.FocusAsync();
        }
    }

    private async Task OnLocationKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter")
        {
            await Move();
        }
    }

    private async Task Move()
    {
        if (_moving) return;
        if (string.IsNullOrWhiteSpace(_articleBarcode) || string.IsNullOrWhiteSpace(_locationBarcode))
        {
            _ok = false;
            _result = "Bitte beide Barcodes angeben.";
            return;
        }

        _moving = true;
        try
        {
            var (ok, message) = await ArticleService.ChangeLocationByBarcodeAsync(_articleBarcode, _locationBarcode, UserId);
            _ok = ok;
            _result = message;
            if (ok)
            {
                _anyChange = true;
                _articleBarcode = string.Empty;
                _locationBarcode = string.Empty;
                await _articleBox.FocusAsync();
            }
        }
        finally
        {
            _moving = false;
        }
    }
}
