@page "/protokolle"
@attribute [Authorize]
@inject ProtocolService ProtocolService
@inject DialogService Dialogs

<PageTitle>Protokolle · Asset Manager</PageTitle>

<RadzenText TextStyle="TextStyle.H4" class="rz-mb-3">Prüfprotokolle</RadzenText>

<RadzenDataGrid Data="@_protocols" TItem="ProtocolService.ProtocolListItem" AllowSorting="true"
                AllowFiltering="true" FilterMode="FilterMode.Advanced" GridLines="DataGridGridLines.Both" AllowColumnResize="true"
                AllowColumnPicking="true" AllowPaging="true" PageSize="25"
                PageSizeOptions="@(new int[] { 10, 25, 50, 100 })" ShowPagingSummary="true"
                RowDoubleClick="@(args => OpenDetail(args.Data!.Id))">
    <Columns>
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="CreatedAt" Title="Erfasst am" Width="150px" FormatString="{0:dd.MM.yyyy HH:mm}" SortOrder="SortOrder.Descending" />
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="CompletedDate" Title="Prüfdatum" Width="120px" FormatString="{0:dd.MM.yyyy}" />
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="ArticleIdentification" Title="Artikel" />
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="CategoryName" Title="Kategorie" Width="150px" />
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="FormName" Title="Formular" Width="160px">
            <Template Context="p">@p.FormName (v@(p.FormVersionNumber))</Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="Result" Title="Ergebnis" Width="140px">
            <Template Context="p">
                <RadzenBadge Text="@InspectionResultInfo.Label(p.Result)" BadgeStyle="@InspectionResultInfo.BadgeStyle(p.Result)" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="IsUnplanned" Title="Art" Width="110px">
            <Template Context="p">@(p.IsUnplanned ? "ungeplant" : "geplant")</Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Property="CreatedByName" Title="Erfasst von" Width="150px" />
        <RadzenDataGridColumn TItem="ProtocolService.ProtocolListItem" Context="p" Title="Aktion" Width="80px" Sortable="false" Filterable="false" Pickable="false" TextAlign="TextAlign.Center">
            <Template Context="p">
                <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" Click="() => OpenDetail(p.Id)" title="Detail öffnen" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private List<ProtocolService.ProtocolListItem> _protocols = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload() => _protocols = await ProtocolService.GetListAsync();

    private async Task OpenDetail(int id)
    {
        await Dialogs.OpenAsync<ProtocolDetailDialog>("Protokoll-Detail",
            new Dictionary<string, object?> { ["ProtocolId"] = id },
            new DialogOptions { Width = "800px", Height = "85%", Resizable = true, Draggable = true });
    }
}
