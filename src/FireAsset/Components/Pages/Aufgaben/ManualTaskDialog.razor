@inject TaskService TaskService
@inject NotificationService Notifications
@inject DialogService Dialogs

<RadzenStack Gap="0.85rem">
    <div>
        <label class="fa-label">Artikel</label>
        <RadzenDropDown @bind-Value="_articleId"
                        Data="@_articles" TextProperty="Identification" ValueProperty="Id"
                        AllowFiltering="true" FilterAsYouType="true"
                        FilterOperator="StringFilterOperator.Contains"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        Placeholder="Tippen zum Filtern…" Style="width: 100%" />
    </div>
    <div>
        <label class="fa-label">Formular</label>
        <RadzenDropDown @bind-Value="_formId"
                        Data="@_forms" TextProperty="Name" ValueProperty="Id"
                        AllowFiltering="true" FilterAsYouType="true"
                        FilterOperator="StringFilterOperator.Contains"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        Placeholder="Formular wählen" Style="width: 100%" />
    </div>
    <div>
        <label class="fa-label">Fälligkeitsdatum</label>
        <input type="date" class="fa-input" @bind="_dueDate" style="max-width: 220px" />
    </div>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(false)" />
        <RadzenButton Text="Anlegen" ButtonStyle="ButtonStyle.Primary" Icon="add" Click="Create" Disabled="@_saving" />
    </RadzenStack>
</RadzenStack>

@code {
    private bool _saving;
    private List<Article> _articles = new();
    private List<Form> _forms = new();
    private int? _articleId;
    private int? _formId;
    private DateTime _dueDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        _articles = await TaskService.GetActiveArticlesAsync();
        _forms = await TaskService.GetActiveFormsAsync();
    }

    private async Task Create()
    {
        if (_saving) return;
        if (_articleId is null || _formId is null)
        {
            Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Hinweis", Detail = "Bitte Artikel und Formular wählen.", Duration = 4000 });
            return;
        }

        _saving = true;
        try
        {
            await TaskService.CreateManualTaskAsync(_articleId.Value, _formId.Value, _dueDate);
            Dialogs.Close(true);
        }
        finally
        {
            _saving = false;
        }
    }
}
