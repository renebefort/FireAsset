@inject InspectionService InspectionService
@inject TaskService TaskService
@inject NotificationService Notifications
@inject DialogService Dialogs
@using System.Globalization

@if (_needsFormSelection)
{
    <RadzenStack Gap="1rem">
        <RadzenText TextStyle="TextStyle.Body2">Wählen Sie das Formular für die ungeplante Prüfung.</RadzenText>
        <div>
            <label class="fa-label">Formular</label>
            <select class="fa-input" @bind="_chosenFormId">
                <option value="">Formular wählen</option>
                @foreach (var f in _forms)
                {
                    <option value="@f.Id">@f.Name</option>
                }
            </select>
        </div>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(false)" />
            <RadzenButton Text="Weiter" ButtonStyle="ButtonStyle.Primary" Icon="arrow_forward" Click="ProceedWithForm" />
        </RadzenStack>
    </RadzenStack>
}
else if (_model is null)
{
    <RadzenText>Das Formular konnte nicht geladen werden (keine aktive Version).</RadzenText>
    <RadzenButton Text="Schließen" Click="() => Dialogs.Close(false)" class="rz-mt-2" />
}
else
{
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-my-0">@ArticleName · @_model.FormName</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenLabel Text="Letzte Werte anzeigen" Component="slv" />
                <RadzenSwitch @bind-Value="_showLast" Name="slv" />
            </RadzenStack>
        </RadzenStack>

        @if (!Unplanned)
        {
            <div>
                <label class="fa-label">Fälligkeitsdatum (vor Ausführung änderbar)</label>
                <input type="date" class="fa-input" @bind="_dueDate" style="max-width: 220px" />
            </div>
        }

        @foreach (var entry in _entries)
        {
            <div>
                @if (entry.Field.FieldType == FieldType.YesNo)
                {
                    <div style="display:flex; align-items:center; gap:0.75rem;">
                        <span style="font-weight:600">
                            @entry.Field.Label
                            @if (!string.IsNullOrEmpty(entry.Field.Unit)) { <span style="font-weight:400"> (@entry.Field.Unit)</span> }
                            @if (!string.IsNullOrEmpty(entry.Field.ReferenceValue)) { <span style="font-weight:400"> · Referenz: @entry.Field.ReferenceValue</span> }
                        </span>
                        <RadzenSwitch @bind-Value="entry.Bool" />
                        <span style="color:#6b7280; font-size:0.85rem;">@(entry.Bool ? "Ja" : "Nein")</span>
                    </div>
                }
                else
                {
                    <label class="fa-label" style="font-weight:600; color:inherit; font-size:0.9rem;">
                        @entry.Field.Label
                        @if (!string.IsNullOrEmpty(entry.Field.Unit)) { <span style="font-weight:400">(@entry.Field.Unit)</span> }
                        @if (!string.IsNullOrEmpty(entry.Field.ReferenceValue)) { <span style="font-weight:400"> · Referenz: @entry.Field.ReferenceValue</span> }
                    </label>

                    @switch (entry.Field.FieldType)
                    {
                        case FieldType.SingleLineText:
                            <input class="fa-input" @bind="entry.Text" />
                            break;
                        case FieldType.Integer:
                            <input type="number" step="1" class="fa-input" @bind="entry.Int" />
                            break;
                        case FieldType.Decimal:
                            <input type="number" step="0.01" class="fa-input" @bind="entry.Dec" />
                            break;
                        case FieldType.MultilineText:
                            <textarea class="fa-input fa-textarea" rows="2" @bind="entry.Text"></textarea>
                            break;
                        case FieldType.Date:
                            <input type="date" class="fa-input" @bind="entry.Date" style="max-width: 220px" />
                            break;
                    }
                }

                @if (_showLast && _model.LastValues.TryGetValue(entry.Field.Label, out var last) && !string.IsNullOrEmpty(last))
                {
                    <div style="font-style:italic; color:#888; font-size:0.85rem; margin-top:2px;">
                        letzte Prüfung: @FormatLast(entry.Field.FieldType, last)
                    </div>
                }
            </div>
        }

        <div>
            <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-1" Style="font-weight:600">Prüfergebnis</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="Bestanden" Icon="check_circle" Click="() => _result = InspectionResult.Bestanden"
                              ButtonStyle="@(_result == InspectionResult.Bestanden ? ButtonStyle.Success : ButtonStyle.Light)" />
                <RadzenButton Text="Mangelhaft" Icon="warning" Click="() => _result = InspectionResult.Mangelhaft"
                              ButtonStyle="@(_result == InspectionResult.Mangelhaft ? ButtonStyle.Warning : ButtonStyle.Light)" />
                <RadzenButton Text="Nicht bestanden" Icon="cancel" Click="() => _result = InspectionResult.NichtBestanden"
                              ButtonStyle="@(_result == InspectionResult.NichtBestanden ? ButtonStyle.Danger : ButtonStyle.Light)" />
            </RadzenStack>
        </div>

        <div>
            <label class="fa-label">Zusatzbemerkungen</label>
            <textarea class="fa-input fa-textarea" rows="2" @bind="_notes"></textarea>
        </div>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(false)" />
            <RadzenButton Text="Speichern" ButtonStyle="ButtonStyle.Primary" Icon="save" Click="Save" />
        </RadzenStack>
    </RadzenStack>
}

@code {
    [Parameter] public int? TaskId { get; set; }
    [Parameter] public int ArticleId { get; set; }
    [Parameter] public int FormId { get; set; }
    [Parameter] public string ArticleName { get; set; } = string.Empty;
    [Parameter] public DateTime? DueDateParam { get; set; }
    [Parameter] public bool Unplanned { get; set; }
    [Parameter] public int? UserId { get; set; }

    private InspectionService.CaptureModel? _model;
    private List<FieldEntry> _entries = new();
    private bool _showLast;
    private InspectionResult? _result;
    private string? _notes;
    private DateTime? _dueDate;
    private bool _needsFormSelection;
    private int? _chosenFormId;
    private List<Form> _forms = new();

    protected override async Task OnInitializedAsync()
    {
        _dueDate = DueDateParam;

        // Ungeplante Prüfung ohne vorgegebenes Formular: zuerst Formular wählen.
        if (Unplanned && FormId == 0)
        {
            _forms = await TaskService.GetActiveFormsAsync();
            _needsFormSelection = true;
            return;
        }

        _chosenFormId = FormId;
        await LoadModel();
    }

    private async Task ProceedWithForm()
    {
        if (_chosenFormId is null)
        {
            Notify("Bitte ein Formular wählen.");
            return;
        }
        _needsFormSelection = false;
        await LoadModel();
    }

    private async Task LoadModel()
    {
        _model = await InspectionService.GetCaptureModelAsync(_chosenFormId!.Value, ArticleId);
        if (_model is not null)
        {
            _entries = _model.Fields.Select(f => new FieldEntry { Field = f }).ToList();
        }
    }

    private async Task Save()
    {
        if (_model is null) return;
        if (_result is null)
        {
            Notify("Bitte ein Prüfergebnis wählen.");
            return;
        }

        var values = _entries.ToDictionary(e => e.Field.Id, e => e.ToStringValue());

        if (Unplanned)
        {
            await InspectionService.ExecuteUnplannedAsync(ArticleId, _model.FormVersionId, values, _result.Value, _notes, UserId);
        }
        else
        {
            if (_dueDate is DateTime d && d != DueDateParam)
            {
                await TaskService.UpdateDueDateAsync(TaskId!.Value, d);
            }
            var completed = DateTime.Now;
            var followUpMsg = await InspectionService.ExecuteTaskAsync(TaskId!.Value, _model.FormVersionId, values, _result.Value, _notes, completed, UserId);
            if (followUpMsg is not null)
            {
                Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "Folgeaufgabe", Detail = followUpMsg, Duration = 8000 });
            }
        }

        Dialogs.Close(true);
    }

    private static string FormatLast(FieldType type, string value)
    {
        if (type == FieldType.Date && DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var d))
        {
            return d.ToString("dd.MM.yyyy");
        }
        return value;
    }

    private void Notify(string message) =>
        Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Hinweis", Detail = message, Duration = 4000 });

    private sealed class FieldEntry
    {
        public FormField Field { get; set; } = default!;
        public bool Bool { get; set; }
        public string? Text { get; set; }
        public int? Int { get; set; }
        public decimal? Dec { get; set; }
        public DateTime? Date { get; set; }

        public string? ToStringValue() => Field.FieldType switch
        {
            FieldType.YesNo => Bool ? "Ja" : "Nein",
            FieldType.SingleLineText => Text,
            FieldType.MultilineText => Text,
            FieldType.Integer => Int?.ToString(CultureInfo.InvariantCulture),
            FieldType.Decimal => Dec?.ToString("0.00", CultureInfo.InvariantCulture),
            FieldType.Date => Date?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture),
            _ => null,
        };
    }
}
