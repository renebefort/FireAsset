@page "/stammdaten/standorte"
@attribute [Authorize]
@inject LocationService LocationService
@inject NotificationService Notifications
@inject DialogService Dialogs

<PageTitle>Standorte · Asset Manager</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-3">
    <RadzenText TextStyle="TextStyle.H4" class="rz-my-0">Standorte</RadzenText>
    <RadzenButton Icon="add" Text="Neuer Standort" ButtonStyle="ButtonStyle.Primary" Click="() => OpenEditor(null)" />
</RadzenStack>

<RadzenDataGrid Data="@_rows" TItem="LocationRow" AllowSorting="true"
                AllowFiltering="true" FilterMode="FilterMode.Advanced" GridLines="DataGridGridLines.Both" AllowColumnResize="true"
                AllowColumnPicking="true" AllowPaging="true" PageSize="20"
                PageSizeOptions="@(new int[] { 10, 20, 50, 100 })" ShowPagingSummary="true"
                RowDoubleClick="@(args => OpenEditor(args.Data!.Id))">
    <Columns>
        <RadzenDataGridColumn TItem="LocationRow" Property="Name" Title="Name" />
        <RadzenDataGridColumn TItem="LocationRow" Property="Path" Title="Pfad" />
        <RadzenDataGridColumn TItem="LocationRow" Property="Barcode" Title="Barcode" Width="160px" />
        <RadzenDataGridColumn TItem="LocationRow" Property="Icon" Title="Icon" Width="160px">
            <Template Context="row">
                <RadzenIcon Icon="@(string.IsNullOrEmpty(row.Icon) ? "place" : row.Icon)" />
                <span class="rz-ml-2">@IconLabel(row.Icon)</span>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LocationRow" Property="Description" Title="Beschreibung" />
        <RadzenDataGridColumn TItem="LocationRow" Context="row" Title="Aktionen" Sortable="false" Filterable="false" Pickable="false" Width="140px" TextAlign="TextAlign.Center">
            <Template Context="row">
                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="() => OpenEditor(row.Id)" title="Bearbeiten" />
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="() => DeleteRow(row)" title="Löschen" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private record IconOption(string Value, string Label);

    /// <summary>Grid-Zeile mit vorberechnetem Pfad, damit die Pfad-Spalte sortier-/filterbar ist.</summary>
    public record LocationRow(int Id, string Name, string Path, string? Barcode, string? Icon, string? Description);

    private static readonly IconOption[] Icons =
    {
        new("folder", "Verzeichnis"),
        new("local_shipping", "LKW / Fahrzeug"),
        new("shelves", "Regal"),
        new("meeting_room", "Raum"),
        new("inventory_2", "Lager"),
        new("person", "Einsatzkraft"),
        new("place", "Sonstiges"),
    };

    private List<LocationRow> _rows = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        var locations = await LocationService.GetAllAsync();
        var byId = locations.ToDictionary(l => l.Id);
        _rows = locations
            .Select(l => new LocationRow(l.Id, l.Name, LocationService.BuildPath(l, byId), l.Barcode, l.Icon, l.Description))
            .OrderBy(r => r.Name)
            .ToList();
    }

    private string IconLabel(string? icon) => Icons.FirstOrDefault(i => i.Value == icon)?.Label ?? "";

    private async Task OpenEditor(int? locationId)
    {
        var result = await Dialogs.OpenAsync<LocationEditDialog>(
            locationId is null ? "Neuer Standort" : "Standort bearbeiten",
            new Dictionary<string, object?> { ["LocationId"] = locationId },
            new DialogOptions { Width = "560px", Resizable = true, Draggable = true });

        if (result is true) await Reload();
    }

    private async Task DeleteRow(LocationRow row)
    {
        var confirmed = await Dialogs.Confirm($"Standort \"{row.Name}\" wirklich löschen?", "Löschen bestätigen",
            new ConfirmOptions { OkButtonText = "Löschen", CancelButtonText = "Abbrechen" });
        if (confirmed != true) return;

        var error = await LocationService.DeleteAsync(row.Id);
        if (error is not null)
        {
            Notify(error);
            return;
        }
        await Reload();
    }

    private void Notify(string message) =>
        Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Hinweis", Detail = message, Duration = 4000 });
}
