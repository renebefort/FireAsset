@inject CategoryService CategoryService
@inject NotificationService Notifications
@inject DialogService Dialogs

<RadzenStack Gap="0.85rem">
    <div>
        <label class="fa-label">Name des Intervalls</label>
        <input class="fa-input" @bind="_interval.Name" />
    </div>

    <label class="fa-checkbox" title="Alternative zum Rhythmus: erzeugt bei der Artikelanlage genau einmal eine Aufgabe (Fälligkeit = Anlagedatum), ohne Folgeaufgaben.">
        <input type="checkbox" @bind="_interval.IsEntryControl" @bind:after="OnEntryControlChanged" /> Eingangskontrolle (einmalig, kein Rhythmus)
    </label>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="12" SizeMd="6">
            <label class="fa-label">Rhythmus (Monate)</label>
            <input type="number" min="1" class="fa-input" @bind="_interval.IntervalMonths"
                   disabled="@_interval.IsEntryControl" />
            @if (_interval.IsEntryControl)
            {
                <RadzenText TextStyle="TextStyle.Caption" class="rz-my-0">Bei Eingangskontrolle ohne Bedeutung.</RadzenText>
            }
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="6">
            <label class="fa-checkbox">
                <input type="checkbox" @bind="_interval.IsActive" /> Aktiv
            </label>
        </RadzenColumn>
    </RadzenRow>

    <div>
        <label class="fa-label">Formular</label>
        <RadzenDropDown @bind-Value="_formId"
                        Data="@_forms" TextProperty="Name" ValueProperty="Id"
                        AllowFiltering="true" FilterAsYouType="true" AllowClear="true"
                        FilterOperator="StringFilterOperator.Contains"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        Placeholder="(kein Formular)" Style="width: 100%" />
    </div>

    @if (_forms.Count == 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">
            Es sind noch keine Formulare vorhanden. Das Intervall kann angelegt und später mit einem Formular verknüpft werden.
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(false)" />
        <RadzenButton Text="Speichern" ButtonStyle="ButtonStyle.Primary" Icon="save" Click="Save" Disabled="@_saving" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public int? IntervalId { get; set; }
    [Parameter] public int CategoryId { get; set; }

    private bool _saving;
    private InspectionInterval _interval = new() { IntervalMonths = 12, IsActive = true };
    private List<Form> _forms = new();
    private int? _formId;

    protected override async Task OnInitializedAsync()
    {
        _forms = await CategoryService.GetFormsAsync();

        if (IntervalId is int id)
        {
            var existing = await CategoryService.GetIntervalAsync(id);
            if (existing is not null) _interval = existing;
        }
        else
        {
            _interval.CategoryId = CategoryId;
        }
        _formId = _interval.FormId;
    }

    private async Task Save()
    {
        if (_saving) return;
        if (string.IsNullOrWhiteSpace(_interval.Name))
        {
            Notify("Der Name des Intervalls ist erforderlich.");
            return;
        }
        if (_interval.IsEntryControl)
        {
            // Eingangskontrolle nutzt keinen Rhythmus.
            _interval.IntervalMonths = 0;
        }
        else if (_interval.IntervalMonths < 1)
        {
            Notify("Der Rhythmus muss mindestens 1 Monat betragen.");
            return;
        }

        _interval.FormId = _formId;

        _saving = true;
        try
        {
            if (_interval.Id == 0)
            {
                _interval.CategoryId = CategoryId;
            }
            var (error, createdTasks) = _interval.Id == 0
                ? await CategoryService.CreateIntervalAsync(_interval)
                : await CategoryService.UpdateIntervalAsync(_interval);
            if (error is not null)
            {
                Notify(error);
                return;
            }
            if (createdTasks > 0)
            {
                Notifications.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Info,
                    Summary = "Aufgabenanlage",
                    Detail = $"{createdTasks} Aufgabe(n) für bestehende Artikel der Kategorie erstellt.",
                    Duration = 8000,
                });
            }
            Dialogs.Close(true);
        }
        finally
        {
            _saving = false;
        }
    }

    private void OnEntryControlChanged()
    {
        // Beim Aktivieren der Eingangskontrolle den Rhythmus visuell leeren.
        if (_interval.IsEntryControl) _interval.IntervalMonths = 0;
        else if (_interval.IntervalMonths < 1) _interval.IntervalMonths = 12;
    }

    private void Notify(string message) =>
        Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Hinweis", Detail = message, Duration = 4000 });
}
