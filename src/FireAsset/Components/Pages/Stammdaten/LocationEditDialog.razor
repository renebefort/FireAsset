@inject LocationService LocationService
@inject NotificationService Notifications
@inject DialogService Dialogs

<RadzenStack Gap="0.85rem">
    <div>
        <label class="fa-label">Name</label>
        <input class="fa-input" @bind="_location.Name" />
    </div>

    <div>
        <label class="fa-label">Übergeordneter Standort</label>
        <RadzenDropDown @bind-Value="_location.ParentLocationId"
                        Data="@_parentOptions" TextProperty="Path" ValueProperty="Id"
                        AllowFiltering="true" FilterAsYouType="true" AllowClear="true"
                        FilterOperator="StringFilterOperator.Contains"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        Placeholder="(kein übergeordneter Standort)" Style="width: 100%" />
    </div>

    <RadzenRow Gap="0.75rem">
        <RadzenColumn Size="12" SizeMd="6">
            <label class="fa-label">Icon</label>
            <select class="fa-input" @bind="_location.Icon">
                @foreach (var i in Icons)
                {
                    <option value="@i.Value">@i.Label</option>
                }
            </select>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="6">
            <label class="fa-label">Barcode</label>
            <input class="fa-input" @bind="_location.Barcode" />
        </RadzenColumn>
    </RadzenRow>

    <div>
        <label class="fa-label">Beschreibung</label>
        <textarea class="fa-input fa-textarea" rows="2" @bind="_location.Description"></textarea>
    </div>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="() => Dialogs.Close(false)" />
        <RadzenButton Text="Speichern" ButtonStyle="ButtonStyle.Primary" Icon="save" Click="Save" Disabled="@_saving" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public int? LocationId { get; set; }

    private bool _saving;

    public record IconOption(string Value, string Label);
    private record ParentOption(int Id, string Path);

    private static readonly IconOption[] Icons =
    {
        new("folder", "Verzeichnis"),
        new("local_shipping", "LKW / Fahrzeug"),
        new("shelves", "Regal"),
        new("meeting_room", "Raum"),
        new("inventory_2", "Lager"),
        new("person", "Einsatzkraft"),
        new("place", "Sonstiges"),
    };

    private Location _location = new() { Icon = "place" };
    private List<ParentOption> _parentOptions = new();

    protected override async Task OnInitializedAsync()
    {
        var all = await LocationService.GetAllAsync();
        var byId = all.ToDictionary(l => l.Id);

        if (LocationId is int id)
        {
            var existing = all.FirstOrDefault(l => l.Id == id);
            if (existing is not null) _location = existing;
        }

        _parentOptions = all
            .Where(l => l.Id != _location.Id)
            .Select(l => new ParentOption(l.Id, LocationService.BuildPath(l, byId)))
            .OrderBy(o => o.Path)
            .ToList();
    }

    private async Task Save()
    {
        // Guard vor der ersten asynchronen Prüfung setzen, damit ein Doppelklick nicht zwei
        // Speichervorgänge (und damit doppelte Standorte) auslösen kann.
        if (_saving) return;
        _saving = true;
        try
        {
            if (string.IsNullOrWhiteSpace(_location.Name))
            {
                Notify("Der Name ist erforderlich.");
                return;
            }
            if (_location.Id != 0 && await LocationService.WouldCreateCycleAsync(_location.Id, _location.ParentLocationId))
            {
                Notify("Ungültige Auswahl: Ein Standort kann nicht sich selbst oder einem Nachfahren untergeordnet werden.");
                return;
            }
            if (!string.IsNullOrWhiteSpace(_location.Barcode) &&
                await LocationService.BarcodeExistsAsync(_location.Barcode, _location.Id == 0 ? null : _location.Id))
            {
                Notify("Dieser Barcode wird bereits verwendet.");
                return;
            }

            var error = _location.Id == 0
                ? await LocationService.CreateAsync(_location)
                : await LocationService.UpdateAsync(_location);
            if (error is not null)
            {
                Notify(error);
                return;
            }
            Dialogs.Close(true);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Notify(string message) =>
        Notifications.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Hinweis", Detail = message, Duration = 4000 });
}
