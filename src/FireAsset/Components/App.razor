<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" href="favicon.svg" type="image/svg+xml" />
    <ResourcePreloader />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/material.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["FireAsset.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="RenderModeForPage" />
    <ReconnectModal />
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script>
        // Viewport-Check für AdaptiveDialogService: derselbe Breakpoint wie das
        // Vollbild-Sheet in app.css (<= 768px => Draggable/Resizable aus).
        window.faViewport = {
            isCompact: () => window.matchMedia('(max-width: 768px)').matches
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Alle Seiten laufen interaktiv (damit u. a. das Menü funktioniert), außer der Login-Seite:
    // Diese muss statisch gerendert werden, damit die Cookie-Anmeldung serverseitig funktioniert.
    private IComponentRenderMode? RenderModeForPage =>
        HttpContext.Request.Path.StartsWithSegments("/login")
            ? null
            : InteractiveServer;
}
